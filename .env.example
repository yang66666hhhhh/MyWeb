# Copy this file to .env before running Docker Compose.

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=personal_growth

# API
DB_CONNECTION=Server=mysql;Port=3306;Database=personal_growth;User=root;Password=change-me-root-password;CharSet=utf8mb4;
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-characters
SECURITY_ENCRYPTION_KEY=change-me-to-a-random-encryption-key
OPENAI_API_KEY=

# Startup initialization for Docker Compose MVP deployments.
DATABASE_AUTO_MIGRATE=true
DATABASE_SEED_ON_STARTUP=true
